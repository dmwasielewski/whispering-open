{
	"name": "whispering-open",
	"type": "module",
	"private": true,
	"version": "7.11.0",
	"description": "Standalone Whispering Open speech-to-text workspace.",
	"keywords": [
		"speech-to-text",
		"transcription",
		"tauri",
		"svelte",
		"whispering"
	],
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/dmwasielewski/whispering-open.git"
	},
	"homepage": "https://github.com/dmwasielewski/whispering-open",
	"license": "AGPL-3.0-or-later",
	"author": "",
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"@types/node": "^24.0.0",
			"@types/bun": "latest",
			"@types/yargs": "^17.0.35",
			"typescript": "^5.9.3",
			"svelte": "^5.45.2",
			"@sveltejs/kit": "^2.49.0",
			"@sveltejs/vite-plugin-svelte": "^6.2.1",
			"svelte-check": "^4.3.4",
			"vite": "^7.2.4",
			"tailwindcss": "^4.1.17",
			"clsx": "latest",
			"tailwind-merge": "^3.4.0",
			"tailwind-variants": "^3.2.2",
			"bits-ui": "^2.14.4",
			"mode-watcher": "^1.1.0",
			"svelte-sonner": "^1.0.6",
			"@lucide/svelte": "^0.561.0",
			"@tanstack/svelte-query": "^6.0.10",
			"@tanstack/svelte-query-devtools": "^6.0.2",
			"@tanstack/svelte-table": "9.0.0-alpha.10",
			"arkregex": "^0.0.5",
			"arktype": "^2.1.29",
			"drizzle-arktype": "^0.1.3",
			"drizzle-kit": "^0.31.7",
			"drizzle-orm": "^0.44.7",
			"nanoid": "latest",
			"wellcrafted": "^0.38.0",
			"date-fns": "^4.1.0",
			"@biomejs/biome": "^2.4.10",
			"turbo": "^2.6.1",
			"wrangler": "^4.71.0",
			"yargs": "^18.0.0",
			"@standard-schema/spec": "^1.1.0",
			"hono": "^4.10.7",
			"mime": "^4.0.6",
			"yjs": "^13.6.29",
			"lib0": "^0.2.117",
			"y-protocols": "^1.0.7",
			"y-indexeddb": "^9.0.12",
			"typebox": "^1.0.0",
			"better-auth": "^1.5.3",
			"@better-auth/oauth-provider": "^1.5.3",
			"@better-auth/drizzle-adapter": "^1.5.3",
			"jsrepo": "^3.6.2",
			"@tailwindcss/vite": "^4.1.11",
			"@tanstack/ai": "^0.8.1",
			"@tanstack/ai-anthropic": "^0.7.0",
			"@tanstack/ai-openai": "^0.7.1",
			"@tanstack/ai-gemini": "^0.8.2",
			"@tanstack/ai-grok": "^0.6.2",
			"@hono/standard-validator": "^0.2.2",
			"hono-openapi": "^1.3.0",
			"fflate": "^0.8.2",
			"@sveltejs/adapter-static": "^3.0.8",
			"@sveltejs/adapter-auto": "^6.1.0",
			"@tailwindcss/typography": "^0.5.19",
			"@sindresorhus/slugify": "^3.0.0",
			"@tauri-apps/api": "^2.9.0",
			"@tauri-apps/plugin-fs": "^2.4.1",
			"@tauri-apps/plugin-opener": "^2.4.0",
			"@tauri-apps/cli": "^2.9.6",
			"marked": "^17.0.3",
			"virtua": "^0.48.5",
			"oauth4webapi": "^3.8.6"
		}
	},
	"packageManager": "bun@1.3.3",
	"scripts": {
		"build": "turbo run build --filter=@whispering-open/app",
		"check": "bun run format:check && bun run lint:check && bun run typecheck",
		"dev": "bun run --cwd apps/whispering dev",
		"dev:web": "bun run --cwd apps/whispering dev:web",
		"build:web": "bun run --cwd apps/whispering build",
		"format": "biome check --write --linter-enabled=false",
		"format:check": "biome ci --linter-enabled=false",
		"lint": "biome lint --write",
		"lint:check": "biome lint",
		"typecheck": "turbo run typecheck --filter=@whispering-open/app",
		"test": "turbo run test",
		"tauri": "bun run --cwd apps/whispering tauri"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@types/bun": "catalog:",
		"turbo": "^2.8.19"
	},
	"dependencies": {
		"@epicenter/constants": "workspace:*"
	},
	"patchedDependencies": {
		"@tanstack/ai@0.8.1": "patches/@tanstack%2Fai@0.8.1.patch"
	}
}
