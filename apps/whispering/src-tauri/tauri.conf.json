{
	"build": {
		"beforeBuildCommand": "bun run build",
		"beforeDevCommand": "bun run dev:web",
		"frontendDist": "../build",
		"devUrl": "http://localhost:1420"
	},
	"bundle": {
		"active": true,
		"category": "Productivity",
		"publisher": "Damian Wasielewski",
		"copyright": "Copyright \u00a9 2026 Damian Wasielewski",
		"homepage": "https://github.com/dmwasielewski/whispering-open",
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"longDescription": "Seamlessly integrate speech-to-text transcriptions anywhere on your desktop. Powered by OpenAI's Whisper API.",
		"shortDescription": "Press shortcut, speak, get text. Free and open source.",
		"createUpdaterArtifacts": true,
		"resources": {
			"recorder-state-icons/*": "recorder-state-icons/"
		},
		"macOS": {
			"entitlements": "entitlements.plist",
			"hardenedRuntime": true,
			"minimumSystemVersion": "10.15",
			"signingIdentity": null
		},
		"linux": {
			"appimage": {
				"bundleMediaFramework": true
			}
		},
		"windows": {
			"webviewInstallMode": {
				"type": "embedBootstrapper"
			},
			"wix": {
				"fipsCompliant": true,
				"language": "en-US"
			},
			"nsis": {
				"compression": "bzip2",
				"installMode": "currentUser"
			}
		}
	},
	"productName": "Whispering Open",
	"version": "7.11.0-4",
	"identifier": "io.github.dmwasielewski.whisperingopen",
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI4MTUwNEE5RDE5OUI1RjgKUldUNHRablJxUVFWdURvLzM5bWZXNVZSMkFONXkrMWhtcjUvRE1ob01JSVBhSnMxYVhqNTFHSW0K",
			"endpoints": [
				"https://github.com/dmwasielewski/whispering-open/releases/latest/download/latest.json"
			]
		}
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"resizable": true,
				"title": "Whispering Open",
				"width": 1080,
				"height": 800,
				"minHeight": 84,
				"minWidth": 72
			}
		],
		"security": {
			"csp": null,
			"assetProtocol": {
				"enable": true,
				"scope": [
					"**"
				]
			}
		}
	}
}
